# CORTEX — Environment Configuration
# Copy to .env and fill in your values

# Required: PostgreSQL with pgvector
DATABASE_URL="postgresql://user:password@host:5432/cortex?sslmode=require"

# Embeddings (choose one)
VOYAGE_API_KEY="pa-..."          # Recommended
# OPENAI_API_KEY="sk-..."        # Alternative
# EMBEDDING_PROVIDER="ollama"    # Local (requires ollama package)

# LLM for dream summaries + entity extraction
ANTHROPIC_API_KEY="sk-ant-..."
# CORTEX_LLM_PROVIDER="anthropic"  # anthropic | openai | openrouter

# Optional
# CORTEX_LLM_ENTITIES="true"    # Enable LLM-based NER ($0.001/ingest)
# OLLAMA_URL="http://localhost:11434"
